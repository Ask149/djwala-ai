# DjwalaAI Configuration
# Copy this file to .env and fill in your values

# Server Configuration
DJWALA_HOST=0.0.0.0
DJWALA_PORT=8000

# CORS Origins (comma-separated or JSON array)
# Use "*" for development, whitelist domains in production
DJWALA_CORS_ORIGINS=["*"]

# Rate Limiting
# Format: "N/minute" or "N/hour" or "N/day"
DJWALA_RATE_LIMIT=5/minute

# Database Path
DJWALA_DATABASE_PATH=djwala_cache.db

# YouTube API Configuration (OPTIONAL)
# Primary method: yt-dlp (metadata-based, no API key needed)
# Secondary method: YouTube Data API v3 (optional fallback for restricted environments)
# 
# Only set this if yt-dlp is blocked in your deployment environment:
# - Get free API key at https://console.cloud.google.com
# - Create new project > Enable "YouTube Data API v3" > Create API key
# - Free tier: 10,000 requests/day
#DJWALA_YOUTUBE_API_KEY=your_youtube_api_key_here
